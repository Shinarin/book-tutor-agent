# Book Tutor Agent — 环境变量配置
# 复制为 .env 并根据需要修改

# --- API 配置 ---
# 多数情况下无需设置：MCP Server 自动继承宿主进程的环境变量
# 仅在使用非标准 API 地址或需要覆盖时手动配置

# Anthropic API (Claude Agent SDK 使用)
# ANTHROPIC_BASE_URL=http://localhost:8080/v1
# ANTHROPIC_API_KEY=sk-xxx

# --- Agent 后端选择 ---
# claude (默认): 使用 Claude Agent SDK
# codex: 使用 OpenAI Codex CLI
# BOOK_TUTOR_AGENT_PROVIDER=claude

# --- 模型选择 ---
# BOOK_TUTOR_CLAUDE_MODEL=claude-opus-4.7
# BOOK_TUTOR_CODEX_MODEL=gpt-5.5
# LLM_MODEL=claude-opus-4.7

# --- TTS (可选，Azure 订阅) ---
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_ENDPOINT=
